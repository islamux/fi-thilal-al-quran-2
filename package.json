{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "cc:build": "cd command-center && pnpm build",
    "cc:mcp": "PROJECT_ROOT=$(pwd)/command-center node command-center/packages/mcp/dist/index.js",
    "ccui": "PROJECT_ROOT=$(pwd)/command-center node command-center/packages/tui/dist/index.js",
    "_cc": "PROJECT_ROOT=$(pwd)/command-center node command-center/packages/mcp/dist/cli.js",
    "cc:status": "pnpm _cc get_project_status",
    "cc:start": "pnpm _cc start_task",
    "cc:complete": "pnpm _cc complete_task",
    "cc:approve": "pnpm _cc approve_task",
    "cc:reject": "pnpm _cc reject_task",
    "cc:list": "pnpm _cc list_tasks",
    "cc:agents": "pnpm _cc list_agents",
    "cc:activity": "pnpm _cc get_activity_feed",
    "cc:reset": "pnpm _cc reset_task",
    "cc:block": "pnpm _cc block_task",
    "cc:unblock": "pnpm _cc unblock_task",
    "cc:mstone": "pnpm _cc get_milestone_overview",
    "cc:task": "pnpm _cc get_task_context",
    "cc:register-agent": "pnpm _cc register_agent",
    "cc:activate": "pnpm _cc activate_milestone",
    "cc:complete-milestone": "pnpm _cc complete_milestone"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "express": "^4.21.2",
    "dotenv": "^17.2.3",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "@types/express": "^4.17.21"
  }
}
